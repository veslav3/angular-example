{
  "name": "angular-example",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "nx:start": "nx serve angular-example",
    "nx:build": "nx build angular-example",
    "nx:watch": "nx build angular-example --watch --configuration development",
    "nx:test": "nx test angular-example",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "serve:ssr:angular-example": "node dist/angular-example/server/server.mjs",
    "docker:build": "docker build -t angular-example:local .",
    "docker:run": "docker run --rm -p 4000:4000 -e PORT=4000 angular-example:local",
    "docker:scout:quickview": "docker scout quickview local://angular-example:local",
    "docker:scout:recommendations": "docker scout recommendations local://angular-example:local",
    "docker:scout": "pnpm run docker:build && pnpm run docker:scout:quickview && pnpm run docker:scout:recommendations"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^22.0.0"
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.7",
    "@ngxs/store": "^21.0.0",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.7",
    "@angular-devkit/schematics": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@nx/angular": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@playwright/test": "^1.59.1",
    "@schematics/angular": "^21.2.7",
    "@types/express": "^5.0.1",
    "@types/node": "^22.15.0",
    "jsdom": "^28.0.0",
    "msw": "^2.13.4",
    "nx": "22.7.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "nice-napi"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}